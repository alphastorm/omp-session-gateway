{
  "name": "omp-session-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "bun run validate:handoff && bun run check:capability-leaks",
    "validate:handoff": "bun scripts/validate-handoff.ts",
    "check:capability-leaks": "bun scripts/check-capability-leaks.ts"
  }
}
