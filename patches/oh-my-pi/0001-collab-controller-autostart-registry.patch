+			_delay?: number,
+			...callbackArguments: unknown[]
+		) => {
+			reconnectScheduled.resolve(() => callback(...callbackArguments));
+			return undefined as never;
+		}) as unknown as typeof setTimeout);
+		first.disconnect();
