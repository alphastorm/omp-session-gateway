+		protectedAcl !== true ||
+		typeof current !== "string" ||
+		current === "S-1-5-18" ||
+		owner !== current ||
+		!rulesValid ||
+		!currentSeen ||
+		!systemSeen
+	) {
+		throw new Error("unsafe OMP Session Gateway publisher token ACL");
