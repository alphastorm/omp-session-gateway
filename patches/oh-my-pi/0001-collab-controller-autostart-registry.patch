+};
+process.on("SIGINT", shutdown);
+process.on("SIGTERM", shutdown);
+await new Promise(() => {});
diff --git a/packages/coding-agent/test/collab/registry-publisher.test.ts b/packages/coding-agent/test/collab/registry-publisher.test.ts
