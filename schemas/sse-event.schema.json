{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/omp-session-gateway/sse-event.schema.json",
  "title": "OMP Session Gateway metadata-only SSE event",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "revision", "sessions"],
      "properties": {
        "type": { "const": "snapshot" },
        "revision": { "type": "integer", "minimum": 0 },
        "sessions": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "session-list.schema.json#/properties/sessions/items" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "revision", "session"],
      "properties": {
        "type": { "const": "session_upsert" },
        "revision": { "type": "integer", "minimum": 1 },
        "session": { "$ref": "session-list.schema.json#/properties/sessions/items" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "revision", "instanceId", "generation"],
      "properties": {
        "type": { "const": "session_remove" },
        "revision": { "type": "integer", "minimum": 1 },
        "instanceId": { "type": "string", "minLength": 16, "maxLength": 128 },
        "generation": { "type": "integer", "minimum": 1 }
      }
    }
  ]
}
